];
const ALLDAYS=['SUN','MON','TUE','WED','THU','FRI','SAT'];
let airlines=[],flights=[],completions={},ds={blockH:72,zoom:3,showAl:true};
function todayKey(){const d=new Date();return d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate();}
function loadData(){
  const a=localStorage.getItem('cop_airlines');airlines=a?JSON.parse(a):JSON.parse(JSON.stringify(DEF_AIRLINES));
  const f=localStorage.getItem('cop_flights');flights=f?JSON.parse(f):JSON.parse(JSON.stringify(DEF_FLIGHTS));
  const c=localStorage.getItem('cop_comp_'+todayKey());completions=c?JSON.parse(c):{};
  const d=localStorage.getItem('cop_display');if(d)ds={...ds,...JSON.parse(d)};
}
function saveData(){
  localStorage.setItem('cop_airlines',JSON.stringify(airlines));
  localStorage.setItem('cop_flights',JSON.stringify(flights));
  localStorage.setItem('cop_comp_'+todayKey(),JSON.stringify(completions));
  localStorage.setItem('cop_display',JSON.stringify(ds));
}
function getColor(name){const a=airlines.find(x=>x.name.toLowerCase()===name.toLowerCase());return a?a.color:'#4466aa';}
function t2m(t){if(!t)return-1;const[h,m]=t.split(':').map(Number);return h*60+m;}
function nowMins(){const n=new Date();return n.getHours()*60+n.getMinutes()+n.getSeconds()/60;}
function todayDay(){return ALLDAYS[new Date().getDay()];}
function todayEvents(){
  const day=todayDay(),evs=[];
  for(const f of flights){
    if(!f.days.includes(day))continue;
    if(f.sealing)evs.push({key:f.id+'_sl',time:f.sealing,lbl:'Sealing',flight:f.flight,airline:f.airline,tc:'type-seal',fr:false});
    if(f.truck)evs.push({key:f.id+'_tr',time:f.truck,lbl:'Truck Dep',flight:f.flight,airline:f.airline,tc:'type-truck',fr:false});
    if(f.eta)evs.push({key:f.id+'_et',time:f.eta,lbl:'ETA',flight:f.flight,airline:f.airline,tc:'type-eta',fr:true});
    if(f.etd)evs.push({key:f.id+'_ed',time:f.etd,lbl:'ETD',flight:f.flight,airline:f.airline,tc:'type-etd',fr:true});
  }
  evs.sort((a,b)=>t2m(a.time)-t2m(b.time));
  return evs;
}
function buildTimeline(){
  const inner=document.getElementById('tl-inner');
  inner.innerHTML='';
  const pxpm=ds.zoom,bh=ds.blockH,total=24*60*pxpm;
  inner.style.height=total+'px';
  inner.style.position='relative';
  for(let h=0;h<24;h++){
    const y=h*60*pxpm;
    const tick=document.createElement('div');
    tick.className='hour-tick';tick.style.top=y+'px';
    inner.appendChild(tick);
    const lbl=document.createElement('div');
    lbl.className='hour-lbl';lbl.style.top=(y+2)+'px';
    lbl.textContent=String(h).padStart(2,'0')+':00';
    inner.appendChild(lbl);
  }
  const nl=document.createElement('div');
  nl.id='now-line-el';nl.style.position='absolute';nl.style.left='0';nl.style.right='0';
  inner.appendChild(nl);
  const evs=todayEvents(),nm=nowMins();
  const BW=164,LANE=60,GAP=4,cols=[];
  function assignCol(mins){
    const endM=mins+bh/pxpm;
    for(let c=0;c<cols.length;c++){if(cols[c]<=mins){cols[c]=endM;return c;}}
    cols.push(endM);return cols.length-1;
  }
  for(const ev of evs){
    const mins=t2m(ev.time);if(mins<0)continue;
    const col=assignCol(mins);
    const y=mins*pxpm;
    const color=getColor(ev.airline);
    const isDone=!!completions[ev.key];
    const isPast=mins<nm;
    const b=document.createElement('div');
    b.className=`eblock ${ev.tc}${isDone?' done':''}${isPast&&!isDone?' past':''}`;
    b.style.cssText=`left:${LANE+col*(BW+GAP)}px;top:${y}px;width:${BW}px;height:${bh}px;border-left-color:${color};`;
    b.dataset.key=ev.key;
    const fc=ev.flight.toLowerCase();
    const liveBtn=`<a class="btn-fr-live" href="https://www.flightradar24.com/${fc}" target="_blank"><span class="fr-dot"></span>Live</a>`;
    const histBtn=ev.fr?`<a class="btn-fr" href="https://www.flightradar24.com/data/flights/${fc}" target="_blank">History</a>`:'';
    const doneBtn=`<button class="btn-done" onclick="toggleDone('${ev.key}')">${isDone?'✓ Done':'Done'}</button>`;
    const alPart=ds.showAl?`<div class="eb-airline">${ev.airline}</div>`:'';
    b.innerHTML=`<div class="eb"><div class="eb-time">${ev.time}</div><div class="eb-type">${ev.lbl}</div><div class="eb-flight">${ev.flight}</div>${alPart}<div class="eb-acts">${doneBtn}${liveBtn}${histBtn}</div>${isDone?'<div class="done-ck">✓</div>':''}</div>`;
    inner.appendChild(b);
  }
  inner.style.minWidth=`${LANE+(cols.length||1)*(BW+GAP)+20}px`;
  updateNL();updateStatus(evs);updateProg(evs);updateLeg();
}
function updateNL(){const nl=document.getElementById('now-line-el');if(!nl)return;nl.style.top=(nowMins()*ds.zoom)+'px';}
function updateStatus(evs){
  const nm=nowMins();let cur=null,nxt=null;
  for(const e of evs){const m=t2m(e.time);if(m<=nm)cur=e;else if(!nxt)nxt=e;}
  document.getElementById('cur-ev').textContent=cur?`${cur.time} ${cur.lbl} ${cur.flight}`:'—';
  document.getElementById('nxt-ev').textContent=nxt?`${nxt.time} ${nxt.lbl} ${nxt.flight}`:'None';
}
function updateProg(evs){
  const tot=evs.length,done=evs.filter(e=>completions[e.key]).length;
  const pct=tot?Math.round(done/tot*100):0;
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('prog-txt').textContent=`${done} / ${tot} done`;
  document.getElementById('done-cnt').textContent=`${done} / ${tot}`;
}
function updateLeg(){
  const leg=document.getElementById('leg');if(!leg)return;
  const used=new Set(todayEvents().map(e=>e.airline));
  leg.innerHTML='';
  for(const a of airlines){
    if(!used.has(a.name))continue;
    const d=document.createElement('div');
    d.className='leg-item';
    d.innerHTML=`<div class="leg-dot" style="background:${a.color}"></div><span>${a.name}</span>`;
    leg.appendChild(d);
  }
}
function toggleDone(key){
  completions[key]=!completions[key];
  if(!completions[key])delete completions[key];
  saveData();buildTimeline();
}
function updateClock(){
  const n=new Date();
  const pad=v=>String(v).padStart(2,'0');
  document.getElementById('clock').textContent=`${pad(n.getHours())}:${pad(n.getMinutes())}:${pad(n.getSeconds())}`;
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const mos=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  document.getElementById('date-str').textContent=`${days[n.getDay()]} ${n.getDate()} ${mos[n.getMonth()]} ${n.getFullYear()}`;
  updateNL();
}
function switchView(v){
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.ntab').forEach(el=>el.classList.remove('active'));
  document.getElementById(v+'-view').classList.add('active');
  document.querySelectorAll('.ntab').forEach(el=>{if(el.textContent.toLowerCase()===v)el.classList.add('active');});
  if(v==='config')renderConfig();
  if(v==='timeline')buildTimeline();
}
document.getElementById('zoom-sl').addEventListener('input',function(){
  document.getElementById('zoom-v').textContent=this.value+'x';
  ds.zoom=parseFloat(this.value);saveData();buildTimeline();
});
document.getElementById('ht-sl').addEventListener('input',function(){
  document.getElementById('ht-v').textContent=this.value;
  ds.blockH=parseInt(this.value);saveData();buildTimeline();
});
document.getElementById('show-al').addEventListener('change',function(){
  ds.showAl=this.checked;saveData();buildTimeline();
});
function cfgApply(){
  const z=parseFloat(document.getElementById('cfg-zm').value);
  const h=parseInt(document.getElementById('cfg-ht').value);
  const sa=document.getElementById('cfg-al').checked;
  document.getElementById('cfg-zm-v').textContent=z+'x';
  document.getElementById('cfg-ht-v').textContent=h+'px';
  ds={zoom:z,blockH:h,showAl:sa};
  document.getElementById('zoom-sl').value=z;document.getElementById('zoom-v').textContent=z+'x';
  document.getElementById('ht-sl').value=h;document.getElementById('ht-v').textContent=h;
  document.getElementById('show-al').checked=sa;
  saveData();buildTimeline();
}
function renderConfig(){
  renderAlTbl();renderFlTbl();
  document.getElementById('cfg-zm').value=ds.zoom;document.getElementById('cfg-zm-v').textContent=ds.zoom+'x';
  document.getElementById('cfg-ht').value=ds.blockH;document.getElementById('cfg-ht-v').textContent=ds.blockH+'px';
  document.getElementById('cfg-al').checked=ds.showAl;
}
function renderAlTbl(){
  const tbody=document.getElementById('al-tbody');tbody.innerHTML='';
  for(const a of airlines){
    const tr=document.createElement('tr');
    tr.innerHTML=`<td><input type="text" value="${a.name}" onchange="updAl('${a.id}','name',this.value)"></td><td><input type="color" value="${a.color}" style="width:40px;height:28px;" onchange="updAl('${a.id}','color',this.value)"></td><td><button class="btn-del" onclick="delAl('${a.id}')">Delete</button></td>`;
    tbody.appendChild(tr);
  }
}
function renderFlTbl(){
  const tbody=document.getElementById('fl-tbody');tbody.innerHTML='';
  for(const f of flights){
    const tr=document.createElement('tr');
    const aOpts=airlines.map(a=>`<option value="${a.name}" ${a.name===f.airline?'selected':''}>${a.name}</option>`).join('');
    const dCbs=ALLDAYS.slice(1).concat([ALLDAYS[0]]).map(d=>`<label class="dcb"><input type="checkbox" ${f.days.includes(d)?'checked':''} onchange="updFlDay('${f.id}','${d}',this.checked)">${d}</label>`).join('');
    tr.innerHTML=`<td style="min-width:130px"><select onchange="updFl('${f.id}','airline',this.value)">${aOpts}</select></td><td><input type="text" value="${f.flight||''}" style="width:75px" onchange="updFl('${f.id}','flight',this.value)"></td><td><input type="time" value="${f.eta||''}" onchange="updFl('${f.id}','eta',this.value)"></td><td><input type="time" value="${f.sealing||''}" onchange="updFl('${f.id}','sealing',this.value)"></td><td><input type="time" value="${f.truck||''}" onchange="updFl('${f.id}','truck',this.value)"></td><td><input type="time" value="${f.etd||''}" onchange="updFl('${f.id}','etd',this.value)"></td><td><div class="daycbs">${dCbs}</div></td><td><button class="btn-del" onclick="delFl('${f.id}')">Del</button></td>`;
    tbody.appendChild(tr);
  }
}
function updAl(id,f,v){const a=airlines.find(x=>x.id===id);if(a){a[f]=v;saveData();showToast('Saved');}}
function delAl(id){if(!confirm('Delete airline?'))return;airlines=airlines.filter(x=>x.id!==id);saveData();renderAlTbl();showToast('Deleted');}
function addAirline(){const id='al_'+Date.now();airlines.push({id,name:'New Airline',color:'#4488cc'});saveData();renderAlTbl();}
function updFl(id,f,v){const fl=flights.find(x=>x.id===id);if(fl){fl[f]=v;saveData();showToast('Saved');}}
function updFlDay(id,day,checked){const f=flights.find(x=>x.id===id);if(!f)return;if(checked&&!f.days.includes(day))f.days.push(day);if(!checked)f.days=f.days.filter(d=>d!==day);saveData();}
function delFl(id){if(!confirm('Delete flight?'))return;flights=flights.filter(x=>x.id!==id);saveData();renderFlTbl();showToast('Deleted');}
function addFlight(){const id='fl_'+Date.now();flights.push({id,airline:airlines[0]?.name||'',flight:'XX000',eta:'',sealing:'',truck:'',etd:'',days:[]});saveData();renderFlTbl();}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1500);}
function togglePanel(){
  const p=document.getElementById('right-panel');
  const icon=document.getElementById('panel-toggle-icon');
  p.classList.toggle('collapsed');
  icon.textContent=p.classList.contains('collapsed')?'▶':'◀';
}
function scrollToNow(){const s=document.getElementById('tl-scroll');if(s)s.scrollTop=Math.max(0,nowMins()*ds.zoom-220);}
loadData();
document.getElementById('zoom-sl').value=ds.zoom;document.getElementById('zoom-v').textContent=ds.zoom+'x';
document.getElementById('ht-sl').value=ds.blockH;document.getElementById('ht-v').textContent=ds.blockH;
document.getElementById('show-al').checked=ds.showAl;
buildTimeline();updateClock();
setInterval(updateClock,1000);
setInterval(()=>{updateNL();const e=todayEvents();updateStatus(e);updateProg(e);},30000);
setTimeout(scrollToNow,400);
</script>
