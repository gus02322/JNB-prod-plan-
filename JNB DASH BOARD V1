<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JNB Catering Ops — Control Board</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;500;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #181b22;
    --border: #252930;
    --text: #d8dce8;
    --text-dim: #5a6070;
    --text-muted: #363c48;
    --accent: #00d4ff;
    --now-line: #ffcc00;
    --done-bg: #0d1a0d;
    --done-border: #1e3a1e;
    --font-mono: 'Share Tech Mono', monospace;
    --font-ui: 'Barlow Condensed', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-ui); min-height: 100vh; overflow-x: hidden; }

/* TOPBAR */
#topbar {
position: fixed; top: 0; left: 0; right: 0; z-index: 200;
background: #0a0c10ee; border-bottom: 1px solid var(–border);
backdrop-filter: blur(8px); display: flex; align-items: center; height: 52px;
}
.logo { padding: 0 20px; font-family: var(–font-ui); font-weight: 900; font-size: 17px; letter-spacing: 3px; text-transform: uppercase; color: var(–accent); border-right: 1px solid var(–border); height: 100%; display: flex; align-items: center; white-space: nowrap; }
#date-str { padding: 0 16px; font-family: var(–font-mono); font-size: 12px; color: var(–text-dim); border-right: 1px solid var(–border); height: 100%; display: flex; align-items: center; }
#clock { font-family: var(–font-mono); font-size: 21px; color: var(–now-line); letter-spacing: 2px; padding: 0 18px; border-right: 1px solid var(–border); height: 100%; display: flex; align-items: center; }
#status-bar { display: flex; flex: 1; height: 100%; }
.spill { padding: 0 16px; border-right: 1px solid var(–border); height: 100%; display: flex; flex-direction: column; justify-content: center; }
.spill .lbl { font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: var(–text-dim); }
.spill .val { font-family: var(–font-mono); font-size: 12px; color: var(–text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px; }
.spill .val.cur { color: #ffaa44; }
.spill .val.nxt { color: #44ffaa; }
#nav-tabs { display: flex; height: 100%; margin-left: auto; }
.ntab { padding: 0 22px; font-family: var(–font-ui); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; border-left: 1px solid var(–border); height: 100%; display: flex; align-items: center; color: var(–text-dim); transition: all 0.15s; user-select: none; }
.ntab:hover { color: var(–text); background: var(–surface); }
.ntab.active { color: var(–accent); background: #001820; }

/* FILTER BAR */
#filter-bar {
position: fixed; top: 52px; left: 0; right: 0; z-index: 190;
background: #0d0f14f0; border-bottom: 1px solid var(–border);
backdrop-filter: blur(6px); display: flex; align-items: center;
height: 36px; padding: 0 16px; gap: 6px;
}
.fbar-lbl { font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(–text-dim); margin-right: 8px; }
.fchk { display: flex; align-items: center; gap: 5px; cursor: pointer; padding: 4px 10px; border-radius: 3px; border: 1px solid var(–border); background: var(–surface); transition: all 0.15s; user-select: none; }
.fchk:hover { border-color: rgba(255,255,255,0.2); }
.fchk input { display: none; }
.fchk-dot { width: 8px; height: 8px; border-radius: 50%; }
.fchk span { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
.fchk.active { border-color: currentColor; background: rgba(255,255,255,0.04); }
.fchk-eta { color: #4dffb4; }
.fchk-seal { color: #ffaa44; }
.fchk-truck { color: #ff6b6b; }
.fchk-etd { color: #66aaff; }

/* VIEWS */
.view { display: none; }
.view.active { display: flex; }
#timeline-view { padding-top: 88px; height: 100vh; overflow: hidden; }
#tl-scroll { flex: 1; overflow-y: auto; overflow-x: auto; position: relative; }
#tl-scroll::-webkit-scrollbar { width: 5px; height: 5px; }
#tl-scroll::-webkit-scrollbar-thumb { background: #2a3040; border-radius: 3px; }
#tl-inner { position: relative; }

/* NOW LINE */
#now-line-el { position: absolute; left: 0; right: 0; height: 2px; background: var(–now-line); z-index: 100; pointer-events: none; }
#now-line-el::before { content: ‘NOW’; position: absolute; left: 54px; top: -9px; font-family: var(–font-mono); font-size: 9px; color: var(–now-line); background: var(–bg); padding: 0 4px; letter-spacing: 1px; }
#now-line-el::after { content: ‘’; position: absolute; left: 48px; top: -3px; width: 8px; height: 8px; border-radius: 50%; background: var(–now-line); }

.hour-tick { position: absolute; left: 0; right: 0; height: 1px; background: var(–border); z-index: 1; }
.hour-lbl { position: absolute; left: 0; width: 54px; font-family: var(–font-mono); font-size: 10px; color: var(–text-muted); padding-right: 8px; text-align: right; z-index: 5; background: var(–bg); }

/* EVENT BLOCKS */
.eblock { position: absolute; border-radius: 3px; border-left: 3px solid; overflow: hidden; cursor: default; transition: filter 0.15s; z-index: 10; background: rgba(20,24,32,0.96); }
.eblock:hover { z-index: 50; filter: brightness(1.3); }
.eblock.done { background: var(–done-bg) !important; border-color: var(–done-border) !important; opacity: 0.4; }
.eblock.past:not(.done) { opacity: 0.55; }
.eb { padding: 4px 6px; height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 1px; position: relative; }
.eb-time { font-family: var(–font-mono); font-size: 10px; color: rgba(255,255,255,0.45); line-height: 1; }
.eb-type { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; line-height: 1; }
.eb-flight { font-family: var(–font-mono); font-size: 13px; line-height: 1; white-space: nowrap; }
.eb-airline { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.35); line-height: 1; }
.eb-acts { display: flex; gap: 3px; margin-top: 3px; flex-wrap: wrap; }

.btn-done { font-family: var(–font-ui); font-size: 9px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 2px 6px; border-radius: 2px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.45); cursor: pointer; transition: all 0.1s; white-space: nowrap; }
.btn-done:hover { background: rgba(255,255,255,0.1); color: #fff; }
.eblock.done .btn-done { color: #1e3a1e; border-color: #1e3a1e; pointer-events: none; }

/* FR24 buttons — only on ETA/ETD */
.btn-fr24 { font-family: var(–font-ui); font-size: 9px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 2px 7px; border-radius: 2px; text-decoration: none; display: inline-flex; align-items: center; gap: 3px; transition: all 0.1s; white-space: nowrap; cursor: pointer; }
.btn-fr24-live { border: 1px solid rgba(255,140,0,0.4); background: rgba(255,140,0,0.07); color: rgba(255,165,0,0.8); }
.btn-fr24-live:hover { background: rgba(255,140,0,0.16); color: #ffcc44; }
.btn-fr24-hist { border: 1px solid rgba(0,212,255,0.25); background: rgba(0,212,255,0.05); color: rgba(0,212,255,0.6); }
.btn-fr24-hist:hover { background: rgba(0,212,255,0.12); color: var(–accent); }
.fr-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; display: inline-block; animation: frpulse 1.4s infinite; }
@keyframes frpulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.done-ck { position: absolute; top: 3px; right: 4px; font-size: 12px; opacity: 0.2; }

.type-eta .eb-type { color: #4dffb4; }
.type-seal .eb-type { color: #ffaa44; }
.type-truck .eb-type { color: #ff6b6b; }
.type-etd .eb-type { color: #66aaff; }

/* RIGHT PANEL */
#right-panel { width: 210px; min-width: 210px; background: var(–surface); border-left: 1px solid var(–border); padding: 14px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; transition: width 0.25s ease, min-width 0.25s ease, padding 0.25s ease; position: relative; }
#right-panel.collapsed { width: 28px; min-width: 28px; padding: 0; overflow: hidden; }
#right-panel.collapsed .psec { opacity: 0; pointer-events: none; }
#panel-toggle { position: absolute; top: 50%; left: 0; transform: translateY(-50%); width: 14px; height: 48px; background: var(–border); border-radius: 3px 0 0 3px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(–text-dim); font-size: 9px; transition: background 0.15s, color 0.15s; user-select: none; z-index: 10; border: 1px solid var(–border); border-right: none; }
#panel-toggle:hover { background: var(–surface2); color: var(–accent); }
#right-panel:not(.collapsed) #panel-toggle { left: auto; right: -14px; border-radius: 0 3px 3px 0; border: 1px solid var(–border); border-left: none; }
#panel-toggle-icon { font-style: normal; font-size: 12px; }
.ptitle { font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(–text-dim); margin-bottom: 7px; padding-bottom: 5px; border-bottom: 1px solid var(–border); }
.progbar { height: 4px; background: var(–border); border-radius: 2px; overflow: hidden; margin-top: 5px; }
.progfill { height: 100%; background: var(–accent); border-radius: 2px; transition: width 1s; }
.progtxt { font-family: var(–font-mono); font-size: 10px; color: var(–text-dim); margin-top: 4px; }
.zrow { display: flex; align-items: center; gap: 7px; margin-bottom: 8px; }
.zrow label { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(–text-dim); min-width: 40px; }
.zrow input[type=range] { flex: 1; accent-color: var(–accent); }
.zrow span { font-family: var(–font-mono); font-size: 10px; color: var(–text); min-width: 24px; text-align: right; }
.trow { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
.trow label { font-size: 10px; color: var(–text-dim); }
.tog { position: relative; width: 30px; height: 15px; }
.tog input { opacity: 0; width: 0; height: 0; }
.tog-sl { position: absolute; inset: 0; background: var(–border); border-radius: 8px; cursor: pointer; transition: 0.2s; }
.tog-sl::before { content: ‘’; position: absolute; left: 2px; top: 1.5px; width: 12px; height: 12px; border-radius: 50%; background: var(–text-dim); transition: 0.2s; }
.tog input:checked + .tog-sl { background: var(–accent); }
.tog input:checked + .tog-sl::before { transform: translateX(15px); background: #fff; }
.leg-item { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; font-size: 10px; color: var(–text); }
.leg-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

/* Export/Import buttons in panel */
.btn-io { width: 100%; font-family: var(–font-ui); font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 0; border-radius: 2px; cursor: pointer; margin-bottom: 5px; transition: all 0.15s; }
.btn-export { background: #001a24; border: 1px solid var(–accent); color: var(–accent); }
.btn-export:hover { background: #002a3a; }
.btn-import { background: #1a1000; border: 1px solid #ffaa44; color: #ffaa44; }
.btn-import:hover { background: #2a1a00; }

/* CONFIG */
#config-view { display: block !important; padding-top: 80px; padding-left: 36px; padding-right: 36px; padding-bottom: 40px; max-width: 1080px; margin: 0 auto; overflow-y: auto; }
#config-view:not(.active) { display: none !important; }
.csec { margin-bottom: 36px; }
.csec h2 { font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(–accent); margin-bottom: 14px; padding-bottom: 7px; border-bottom: 1px solid var(–border); }
.ctbl { width: 100%; border-collapse: collapse; font-size: 12px; }
.ctbl th { text-align: left; padding: 7px 9px; background: var(–surface); color: var(–text-dim); font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; border-bottom: 1px solid var(–border); }
.ctbl td { padding: 5px 9px; border-bottom: 1px solid var(–border); vertical-align: middle; color: var(–text); }
.ctbl tr:hover td { background: var(–surface); }
.ctbl input[type=text], .ctbl input[type=time], .ctbl select { background: var(–bg); border: 1px solid var(–border); color: var(–text); font-family: var(–font-mono); font-size: 11px; padding: 3px 6px; border-radius: 2px; width: 100%; }
.ctbl input[type=color] { width: 34px; height: 24px; border: 1px solid var(–border); background: none; cursor: pointer; border-radius: 2px; padding: 1px; }
.daycbs { display: flex; gap: 5px; flex-wrap: wrap; }
.dcb { display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 8px; letter-spacing: 1px; text-transform: uppercase; color: var(–text-dim); cursor: pointer; }
.dcb input[type=checkbox] { accent-color: var(–accent); cursor: pointer; }
.btn-add { background: #001a24; border: 1px solid var(–accent); color: var(–accent); font-family: var(–font-ui); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 7px 16px; border-radius: 2px; cursor: pointer; transition: all 0.15s; margin-top: 9px; }
.btn-add:hover { background: #002a3a; }
.btn-del { background: #1a0005; border: 1px solid #5a0010; color: #ff4466; font-family: var(–font-ui); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 7px; border-radius: 2px; cursor: pointer; white-space: nowrap; }
.btn-del:hover { background: #2a0010; }
.drow { display: flex; align-items: center; gap: 14px; margin-bottom: 13px; }
.drow label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(–text-dim); min-width: 150px; }
.drow input[type=range] { flex: 1; max-width: 180px; accent-color: var(–accent); }
.drow span { font-family: var(–font-mono); font-size: 11px; color: var(–text); min-width: 40px; }

#toast { position: fixed; bottom: 20px; right: 20px; background: var(–surface); border: 1px solid var(–accent); color: var(–accent); font-family: var(–font-mono); font-size: 11px; padding: 8px 16px; border-radius: 3px; z-index: 999; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
#toast.show { opacity: 1; }
#file-import { display: none; }
</style>

</head>
<body>

<div id="topbar">
  <div class="logo">⬡ JNB CATERING OPS</div>
  <div id="date-str"></div>
  <div id="clock">00:00:00</div>
  <div id="status-bar">
    <div class="spill"><div class="lbl">Current</div><div class="val cur" id="cur-ev">—</div></div>
    <div class="spill"><div class="lbl">Next</div><div class="val nxt" id="nxt-ev">—</div></div>
    <div class="spill"><div class="lbl">Done</div><div class="val" id="done-cnt">0 / 0</div></div>
  </div>
  <div id="nav-tabs">
    <div class="ntab active" onclick="switchView('timeline')">Timeline</div>
    <div class="ntab" onclick="switchView('config')">Config</div>
  </div>
</div>

<!-- FILTER BAR -->

<div id="filter-bar">
  <span class="fbar-lbl">Show</span>
  <label class="fchk fchk-eta active" id="fchk-eta">
    <input type="checkbox" checked onchange="toggleFilter('eta',this.checked)">
    <span class="fchk-dot" style="background:#4dffb4"></span>
    <span>ETA</span>
  </label>
  <label class="fchk fchk-etd active" id="fchk-etd">
    <input type="checkbox" checked onchange="toggleFilter('etd',this.checked)">
    <span class="fchk-dot" style="background:#66aaff"></span>
    <span>ETD</span>
  </label>
  <label class="fchk fchk-seal active" id="fchk-seal">
    <input type="checkbox" checked onchange="toggleFilter('seal',this.checked)">
    <span class="fchk-dot" style="background:#ffaa44"></span>
    <span>Sealing</span>
  </label>
  <label class="fchk fchk-truck active" id="fchk-truck">
    <input type="checkbox" checked onchange="toggleFilter('truck',this.checked)">
    <span class="fchk-dot" style="background:#ff6b6b"></span>
    <span>Truck Dep</span>
  </label>
</div>

<div id="timeline-view" class="view active">
  <div id="tl-scroll">
    <div id="tl-inner"></div>
  </div>
  <div id="right-panel">
    <div id="panel-toggle" onclick="togglePanel()"><span id="panel-toggle-icon">◀</span></div>
    <div class="psec">
      <div class="ptitle">Day Progress</div>
      <div class="progbar"><div class="progfill" id="prog-fill" style="width:0%"></div></div>
      <div class="progtxt" id="prog-txt">0 / 0 done</div>
    </div>
    <div class="psec">
      <div class="ptitle">View</div>
      <div class="zrow"><label>Zoom</label><input type="range" id="zoom-sl" min="1" max="8" value="3" step="0.5"><span id="zoom-v">3x</span></div>
      <div class="zrow"><label>Height</label><input type="range" id="ht-sl" min="44" max="120" value="72" step="4"><span id="ht-v">72</span></div>
      <div class="trow" style="margin-top:4px;"><label>Airline Name</label><label class="tog"><input type="checkbox" id="show-al" checked><span class="tog-sl"></span></label></div>
    </div>
    <div class="psec">
      <div class="ptitle">Airlines Today</div>
      <div id="leg"></div>
    </div>
    <div class="psec">
      <div class="ptitle">Event Types</div>
      <div style="font-size:10px;line-height:1.9;color:var(--text-dim);">
        <span style="color:#4dffb4;">●</span> ETA Arrival<br>
        <span style="color:#ffaa44;">●</span> Sealing & Loading<br>
        <span style="color:#ff6b6b;">●</span> Truck Departure<br>
        <span style="color:#66aaff;">●</span> ETD Departure
      </div>
    </div>
    <div class="psec">
      <div class="ptitle">Data Sync</div>
      <button class="btn-io btn-export" onclick="exportData()">⬇ Export Config</button>
      <button class="btn-io btn-import" onclick="document.getElementById('file-import').click()">⬆ Import Config</button>
      <input type="file" id="file-import" accept=".json" onchange="importData(this)">
    </div>
  </div>
</div>

<div id="config-view" class="view">
  <div class="csec">
    <h2>Airlines</h2>
    <table class="ctbl"><thead><tr><th>Name</th><th>Color</th><th></th></tr></thead><tbody id="al-tbody"></tbody></table>
    <button class="btn-add" onclick="addAirline()">+ Add Airline</button>
  </div>
  <div class="csec">
    <h2>Flights</h2>
    <table class="ctbl">
      <thead><tr><th>Airline</th><th>Flight</th><th>ETA</th><th>Sealing</th><th>Truck</th><th>ETD</th><th>Operating Days</th><th></th></tr></thead>
      <tbody id="fl-tbody"></tbody>
    </table>
    <button class="btn-add" onclick="addFlight()">+ Add Flight</button>
  </div>
  <div class="csec">
    <h2>Display Settings</h2>
    <div class="drow"><label>Block Height</label><input type="range" min="44" max="120" value="72" step="4" id="cfg-ht" oninput="cfgApply()"><span id="cfg-ht-v">72px</span></div>
    <div class="drow"><label>Timeline Zoom</label><input type="range" min="1" max="8" value="3" step="0.5" id="cfg-zm" oninput="cfgApply()"><span id="cfg-zm-v">3x</span></div>
    <div class="drow"><label>Show Airline Name</label><label class="tog"><input type="checkbox" id="cfg-al" checked onchange="cfgApply()"><span class="tog-sl"></span></label></div>
  </div>
</div>

<div id="toast"></div>

<script>
const DEF_AIRLINES = [
  {id:'emirates',name:'Emirates',color:'#e31837'},
  {id:'qantas',name:'Qantas',color:'#ff5500'},
  {id:'lufthansa',name:'Lufthansa',color:'#8844cc'},
  {id:'british_airways',name:'British Airways',color:'#2255aa'},
  {id:'virgin_atlantic',name:'Virgin Atlantic',color:'#cc0055'},
  {id:'ethiopian',name:'Ethiopian',color:'#078930'},
  {id:'cathay',name:'Cathay',color:'#006564'},
  {id:'united',name:'United',color:'#4a6ea8'},
  {id:'delta',name:'Delta',color:'#003399'},
  {id:'air_china',name:'Air China',color:'#cc2200'},
  {id:'etihad',name:'Etihad',color:'#b8973a'},
  {id:'air_mauritius',name:'Air Mauritius',color:'#009966'},
  {id:'air_algerie',name:'Air Algerie',color:'#00aa44'},
  {id:'air_seychelles',name:'Air Seychelles',color:'#1a9fd4'},
  {id:'latam',name:'Latam',color:'#e61f26'},
  {id:'uganda',name:'Uganda',color:'#d4aa00'},
  {id:'egyptair',name:'EgyptAir',color:'#bf0000'},
  {id:'air_austral',name:'Air Austral',color:'#0066cc'},
  {id:'asky',name:'Asky',color:'#ee7700'},
  {id:'air_cote',name:"Air Cote D'Ivoire",color:'#ff7700'},
  {id:'qantas_perth',name:'Qantas PERTH',color:'#ff8c00'},
];
const DEF_FLIGHTS = [
  {id:'f1',airline:"Air Cote D'Ivoire",flight:'HF903',eta:'01:25',etd:'03:00',sealing:'00:00',truck:'01:00',days:['MON','TUE','WED','THU','FRI','SAT','SUN']},
  {id:'f2',airline:'Asky',flight:'KP0073',eta:'01:35',etd:'03:40',sealing:'00:00',truck:'01:00',days:['MON','TUE','WED','THU','FRI','SAT','SUN']},
