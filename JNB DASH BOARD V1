<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JNB Catering Ops — Control Board</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;500;600;700;900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #181b22;
    --border: #252930;
    --text: #d8dce8;
    --text-dim: #5a6070;
    --text-muted: #363c48;
    --accent: #00d4ff;
    --now-line: #ffcc00;
    --done-bg: #0d1a0d;
    --done-border: #1e3a1e;
    --done-text: #2a5a2a;
    --font-mono: 'Share Tech Mono', monospace;
    --font-ui: 'Barlow Condensed', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-ui); min-height: 100vh; overflow-x: hidden; }
  #topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    background: #0a0c10ee; border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px); display: flex; align-items: center;
    height: 52px;
  }
  .logo {
    padding: 0 20px; font-family: var(--font-ui); font-weight: 900;
    font-size: 17px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); border-right: 1px solid var(--border);
    height: 100%; display: flex; align-items: center; white-space: nowrap;
  }
  #date-str {
    padding: 0 16px; font-family: var(--font-mono); font-size: 12px;
    color: var(--text-dim); border-right: 1px solid var(--border);
    height: 100%; display: flex; align-items: center;
  }
  #clock {
    font-family: var(--font-mono); font-size: 21px; color: var(--now-line);
    letter-spacing: 2px; padding: 0 18px; border-right: 1px solid var(--border);
    height: 100%; display: flex; align-items: center;
  }
  #status-bar { display: flex; flex: 1; height: 100%; }
  .spill {
    padding: 0 16px; border-right: 1px solid var(--border);
    height: 100%; display: flex; flex-direction: column; justify-content: center;
  }
  .spill .lbl { font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-dim); }
  .spill .val { font-family: var(--font-mono); font-size: 12px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px; }
  .spill .val.cur { color: #ffaa44; }
  .spill .val.nxt { color: #44ffaa; }
  #nav-tabs { display: flex; height: 100%; margin-left: auto; }
  .ntab {
    padding: 0 22px; font-family: var(--font-ui); font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
    border-left: 1px solid var(--border); height: 100%;
    display: flex; align-items: center; color: var(--text-dim); transition: all 0.15s;
    user-select: none;
  }
  .ntab:hover { color: var(--text); background: var(--surface); }
  .ntab.active { color: var(--accent); background: #001820; }
  .view { display: none; }
  .view.active { display: flex; }
  #timeline-view { padding-top: 52px; height: 100vh; overflow: hidden; }
  #tl-scroll { flex: 1; overflow-y: auto; overflow-x: auto; position: relative; }
  #tl-scroll::-webkit-scrollbar { width: 5px; height: 5px; }
  #tl-scroll::-webkit-scrollbar-thumb { background: #2a3040; border-radius: 3px; }
  #tl-inner { position: relative; }
  #now-line-el {
    position: absolute; left: 0; right: 0; height: 2px;
    background: var(--now-line); z-index: 100; pointer-events: none;
  }
  #now-line-el::before {
    content: 'NOW'; position: absolute; left: 54px; top: -9px;
    font-family: var(--font-mono); font-size: 9px; color: var(--now-line);
    background: var(--bg); padding: 0 4px; letter-spacing: 1px;
  }
  #now-line-el::after {
    content: ''; position: absolute; left: 48px; top: -3px;
    width: 8px; height: 8px; border-radius: 50%; background: var(--now-line);
  }
  .hour-tick { position: absolute; left: 0; right: 0; height: 1px; background: var(--border); z-index: 1; }
  .hour-lbl {
    position: absolute; left: 0; width: 54px;
    font-family: var(--font-mono); font-size: 10px; color: var(--text-muted);
    padding-right: 8px; text-align: right; z-index: 5; background: var(--bg);
  }
  .eblock {
    position: absolute; border-radius: 3px; border-left: 3px solid;
    overflow: hidden; cursor: default; transition: filter 0.15s; z-index: 10;
    background: rgba(20,24,32,0.96);
  }
  .eblock:hover { z-index: 50; filter: brightness(1.3); }
  .eblock.done { background: var(--done-bg) !important; border-color: var(--done-border) !important; opacity: 0.4; }
  .eblock.past:not(.done) { opacity: 0.55; }
  .eb { padding: 4px 6px; height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 1px; position: relative; }
  .eb-time { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.45); line-height: 1; }
  .eb-type { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; line-height: 1; }
  .eb-flight { font-family: var(--font-mono); font-size: 13px; line-height: 1; white-space: nowrap; }
  .eb-airline { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.35); line-height: 1; }
  .eb-acts { display: flex; gap: 3px; margin-top: 3px; flex-wrap: wrap; }
  .btn-done {
    font-family: var(--font-ui); font-size: 9px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase; padding: 2px 6px;
    border-radius: 2px; border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.45);
    cursor: pointer; transition: all 0.1s; white-space: nowrap;
  }
  .btn-done:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .eblock.done .btn-done { color: #1e3a1e; border-color: #1e3a1e; pointer-events: none; }
  .btn-fr {
    font-family: var(--font-ui); font-size: 9px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase; padding: 2px 6px;
    border-radius: 2px; border: 1px solid rgba(0,212,255,0.2);
    background: rgba(0,212,255,0.05); color: rgba(0,212,255,0.55);
    cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 3px;
    transition: all 0.1s; white-space: nowrap;
  }
  .btn-fr:hover { background: rgba(0,212,255,0.12); color: var(--accent); }
  .btn-fr-live {
    font-family: var(--font-ui); font-size: 9px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase; padding: 2px 6px;
    border-radius: 2px; border: 1px solid rgba(255,170,0,0.3);
    background: rgba(255,170,0,0.06); color: rgba(255,170,0,0.7);
    cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 3px;
    transition: all 0.1s; white-space: nowrap;
  }
  .btn-fr-live:hover { background: rgba(255,170,0,0.14); color: #ffcc44; }
  .fr-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; display: inline-block; animation: frpulse 1.4s infinite; }
  @keyframes frpulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .done-ck { position: absolute; top: 3px; right: 4px; font-size: 12px; opacity: 0.2; }
  .type-eta .eb-type { color: #4dffb4; }
  .type-seal .eb-type { color: #ffaa44; }
  .type-truck .eb-type { color: #ff6b6b; }
  .type-etd .eb-type { color: #66aaff; }
  #right-panel {
    width: 210px; min-width: 210px; background: var(--surface);
    border-left: 1px solid var(--border); padding: 14px;
    overflow-y: auto; display: flex; flex-direction: column; gap: 14px;
    transition: width 0.25s ease, min-width 0.25s ease, padding 0.25s ease;
    position: relative;
  }
  #right-panel.collapsed { width: 28px; min-width: 28px; padding: 0; overflow: hidden; }
  #right-panel.collapsed .psec { opacity: 0; pointer-events: none; }
  #panel-toggle {
    position: absolute; top: 50%; left: 0; transform: translateY(-50%);
    width: 14px; height: 48px; background: var(--border);
    border-radius: 3px 0 0 3px; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    color: var(--text-dim); font-size: 9px;
    transition: background 0.15s, color 0.15s;
    user-select: none; z-index: 10;
    border: 1px solid var(--border); border-right: none;
  }
  #panel-toggle:hover { background: var(--surface2); color: var(--accent); }
  #right-panel:not(.collapsed) #panel-toggle { left: auto; right: -14px; border-radius: 0 3px 3px 0; border: 1px solid var(--border); border-left: none; }
  #panel-toggle-icon { font-style: normal; font-size: 12px; }
  .psec { }
  .ptitle {
    font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: var(--text-dim); margin-bottom: 7px; padding-bottom: 5px; border-bottom: 1px solid var(--border);
  }
  .progbar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 5px; }
  .progfill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 1s; }
  .progtxt { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); margin-top: 4px; }
  .zrow { display: flex; align-items: center; gap: 7px; margin-bottom: 8px; }
  .zrow label { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dim); min-width: 40px; }
  .zrow input[type=range] { flex: 1; accent-color: var(--accent); }
  .zrow span { font-family: var(--font-mono); font-size: 10px; color: var(--text); min-width: 24px; text-align: right; }
  .trow { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
  .trow label { font-size: 10px; color: var(--text-dim); }
  .tog { position: relative; width: 30px; height: 15px; }
  .tog input { opacity: 0; width: 0; height: 0; }
  .tog-sl { position: absolute; inset: 0; background: var(--border); border-radius: 8px; cursor: pointer; transition: 0.2s; }
  .tog-sl::before { content: ''; position: absolute; left: 2px; top: 1.5px; width: 12px; height: 12px; border-radius: 50%; background: var(--text-dim); transition: 0.2s; }
  .tog input:checked + .tog-sl { background: var(--accent); }
  .tog input:checked + .tog-sl::before { transform: translateX(15px); background: #fff; }
  .leg-item { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; font-size: 10px; color: var(--text); }
  .leg-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  #config-view {
    display: block !important; padding-top: 68px; padding-left: 36px;
    padding-right: 36px; padding-bottom: 40px; max-width: 1080px;
    margin: 0 auto; overflow-y: auto;
  }
  #config-view:not(.active) { display: none !important; }
  .csec { margin-bottom: 36px; }
  .csec h2 {
    font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); margin-bottom: 14px; padding-bottom: 7px; border-bottom: 1px solid var(--border);
  }
  .ctbl { width: 100%; border-collapse: collapse; font-size: 12px; }
  .ctbl th {
    text-align: left; padding: 7px 9px; background: var(--surface);
    color: var(--text-dim); font-size: 9px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; border-bottom: 1px solid var(--border);
  }
  .ctbl td { padding: 5px 9px; border-bottom: 1px solid var(--border); vertical-align: middle; color: var(--text); }
  .ctbl tr:hover td { background: var(--surface); }
  .ctbl input[type=text], .ctbl input[type=time], .ctbl select {
    background: var(--bg); border: 1px solid var(--border); color: var(--text);
    font-family: var(--font-mono); font-size: 11px; padding: 3px 6px;
    border-radius: 2px; width: 100%;
  }
  .ctbl input[type=color] { width: 34px; height: 24px; border: 1px solid var(--border); background: none; cursor: pointer; border-radius: 2px; padding: 1px; }
  .daycbs { display: flex; gap: 5px; flex-wrap: wrap; }
  .dcb { display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 8px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dim); cursor: pointer; }
  .dcb input[type=checkbox] { accent-color: var(--accent); cursor: pointer; }
  .btn-add { background: #001a24; border: 1px solid var(--accent); color: var(--accent); font-family: var(--font-ui); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 7px 16px; border-radius: 2px; cursor: pointer; transition: all 0.15s; margin-top: 9px; }
  .btn-add:hover { background: #002a3a; }
  .btn-del { background: #1a0005; border: 1px solid #5a0010; color: #ff4466; font-family: var(--font-ui); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; padding: 3px 7px; border-radius: 2px; cursor: pointer; white-space: nowrap; }
  .btn-del:hover { background: #2a0010; }
  .drow { display: flex; align-items: center; gap: 14px; margin-bottom: 13px; }
  .drow label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dim); min-width: 150px; }
  .drow input[type=range] { flex: 1; max-width: 180px; accent-color: var(--accent); }
  .drow span { font-family: var(--font-mono); font-size: 11px; color: var(--text); min-width: 40px; }
  #toast { position: fixed; bottom: 20px; right: 20px; background: var(--surface); border: 1px solid var(--accent); color: var(--accent); font-family: var(--font-mono); font-size: 11px; padding: 8px 16px; border-radius: 3px; z-index: 999; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
  #toast.show { opacity: 1; }
</style>
</head>
<body>
<div id="topbar">
  <div class="logo">⬡ JNB CATERING OPS</div>
  <div id="date-str"></div>
  <div id="clock">00:00:00</div>
  <div id="status-bar">
    <div class="spill"><div class="lbl">Current</div><div class="val cur" id="cur-ev">—</div></div>
    <div class="spill"><div class="lbl">Next</div><div class="val nxt" id="nxt-ev">—</div></div>
    <div class="spill"><div class="lbl">Done</div><div class="val" id="done-cnt">0 / 0</div></div>
  </div>
  <div id="nav-tabs">
    <div class="ntab active" onclick="switchView('timeline')">Timeline</div>
    <div class="ntab" onclick="switchView('config')">Config</div>
  </div>
</div>
<div id="timeline-view" class="view active">
  <div id="tl-scroll">
    <div id="tl-inner"></div>
  </div>
  <div id="right-panel">
    <div id="panel-toggle" onclick="togglePanel()" title="Réduire / Agrandir"><span id="panel-toggle-icon">◀</span></div>
    <div class="psec">
      <div class="ptitle">Day Progress</div>
      <div class="progbar"><div class="progfill" id="prog-fill" style="width:0%"></div></div>
      <div class="progtxt" id="prog-txt">0 / 0 done</div>
    </div>
    <div class="psec">
      <div class="ptitle">View</div>
      <div class="zrow"><label>Zoom</label><input type="range" id="zoom-sl" min="1" max="8" value="3" step="0.5"><span id="zoom-v">3x</span></div>
      <div class="zrow"><label>Height</label><input type="range" id="ht-sl" min="44" max="120" value="72" step="4"><span id="ht-v">72</span></div>
      <div class="trow" style="margin-top:4px;"><label>Airline Name</label><label class="tog"><input type="checkbox" id="show-al" checked><span class="tog-sl"></span></label></div>
    </div>
    <div class="psec">
      <div class="ptitle">Airlines Today</div>
      <div id="leg"></div>
    </div>
    <div class="psec">
      <div class="ptitle">Event Types</div>
      <div style="font-size:10px;line-height:1.9;color:var(--text-dim);">
        <span style="color:#4dffb4;">●</span> ETA Arrival<br>
        <span style="color:#ffaa44;">●</span> Sealing & Loading<br>
        <span style="color:#ff6b6b;">●</span> Truck Departure<br>
        <span style="color:#66aaff;">●</span> ETD Departure
      </div>
    </div>
  </div>
</div>
<div id="config-view" class="view">
  <div class="csec">
    <h2>Airlines</h2>
    <table class="ctbl"><thead><tr><th>Name</th><th>Color</th><th></th></tr></thead><tbody id="al-tbody"></tbody></table>
    <button class="btn-add" onclick="addAirline()">+ Add Airline</button>
  </div>
  <div class="csec">
    <h2>Flights</h2>
    <table class="ctbl">
      <thead><tr><th>Airline</th><th>Flight</th><th>ETA</th><th>Sealing</th><th>Truck</th><th>ETD</th><th>Operating Days</th><th></th></tr></thead>
      <tbody id="fl-tbody"></tbody>
    </table>
    <button class="btn-add" onclick="addFlight()">+ Add Flight</button>
  </div>
  <div class="csec">
    <h2>Display Settings</h2>
    <div class="drow"><label>Block Height</label><input type="range" min="44" max="120" value="72" step="4" id="cfg-ht" oninput="cfgApply()"><span id="cfg-ht-v">72px</span></div>
    <div class="drow"><label>Timeline Zoom</label><input type="range" min="1" max="8" value="3" step="0.5" id="cfg-zm" oninput="cfgApply()"><span id="cfg-zm-v">3x</span></div>
    <div class="drow"><label>Show Airline Name</label><label class="tog"><input type="checkbox" id="cfg-al" checked onchange="cfgApply()"><span class="tog-sl"></span></label></div>
  </div>
</div>
<div id="toast"></div>
<script>
